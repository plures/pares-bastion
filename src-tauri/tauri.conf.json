{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Pares Bastion",
  "version": "0.1.0",
  "identifier": "app.plures.netops-toolkit",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pares Bastion",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/netops-scan"
    ]
  },
  "plugins": {
    "shell": {
      "open": false,
      "scope": [
        {
          "name": "binaries/netops-scan",
          "sidecar": true
        }
      ]
    }
  }
}